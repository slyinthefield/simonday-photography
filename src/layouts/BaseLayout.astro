---
import '../styles/global.css';
const { title, overlayNav = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Simon Day</title>
  </head>
  <body>
    <header class={`site-header${overlayNav ? ' site-header--overlay' : ''}`}>
      <a href="/" class="site-name">Simon Day</a>
      <nav class="site-nav">
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/prints">Prints</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
