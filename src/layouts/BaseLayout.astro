---
import '../styles/global.css';
const { title, overlayNav = false } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/work'
    ? path === '/work' || path.startsWith('/work/')
    : path === href;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Simon Day</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
  <body>
    <header class={`site-header${overlayNav ? ' site-header--overlay' : ''}`}>
      <a href="/" class="site-monogram" aria-label="Simon Day Photography">
        <span class="monogram-s">S</span>
        <span class="monogram-d">D</span>
      </a>
      <nav class="site-nav">
        <a href="/work" class:list={[{ active: isActive('/work') }]}>Work</a>
        <a href="/about" class:list={[{ active: isActive('/about') }]}>About</a>
        <a href="/prints" class:list={[{ active: isActive('/prints') }]}>Prints</a>
        <a href="/contact" class:list={[{ active: isActive('/contact') }]}>Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", (user) => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
