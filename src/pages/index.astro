---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { heroImage, coverImage } from '../utils/cloudinary';
import siteSettings from '../data/site-settings.json';

const allSeries = await getCollection('series');
const featuredSeries = allSeries
  .filter((s) => s.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 4);
---
<BaseLayout title="Home" overlayNav={true}>
  <section class="hero" style={siteSettings.heroImage ? `background-image: url(${heroImage(siteSettings.heroImage)})` : ''}>
    <h1 class="hero__title">Simon<br />Day</h1>
    <span class="hero__scroll-hint">Scroll</span>
  </section>
  <section class="home-grid">
    <p class="home-grid__label">Selected work</p>
    <div class="home-series-grid">
      {featuredSeries.map((series) => (
        <a href={`/work/${series.id}`} class="series-card">
          <div class="series-card__image">
            {series.data.coverImage
              ? <img src={coverImage(series.data.coverImage)} alt={series.data.title} loading="lazy" />
              : <div class="series-card__placeholder"></div>
            }
          </div>
          <div class="series-card__info">
            <p class="series-card__title">{series.data.title}</p>
            <p class="series-card__meta">{series.data.year} · {series.data.images.length} images</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>