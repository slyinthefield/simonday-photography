---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Prints">
  <div class="page-content">
    <h1 class="page-title">Prints</h1>
    <div class="page-body">
      <p>A curated selection available to order. Full listings coming soon.</p>
      <p style="margin-top: 1.5rem;">For enquiries in the meantime, <a href="/contact" style="color: var(--accent); border-bottom: 1px solid var(--accent); padding-bottom: 1px;">get in touch</a>.</p>
    </div>
  </div>
</BaseLayout>
