---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Work">
  <div class="work-index">
    <div class="work-index__header">
      <h1 class="work-index__title">Work</h1>
    </div>
    <div class="work-grid">
      <a href="/work/new-zealand-south-island" class="series-card">
        <div class="series-card__placeholder"></div>
        <div class="series-card__info">
          <p class="series-card__title">New Zealand — South Island</p>
          <p class="series-card__meta">New Zealand · 2025 · 18 images</p>
        </div>
      </a>
      <a href="/work/new-zealand-north-island" class="series-card">
        <div class="series-card__placeholder"></div>
        <div class="series-card__info">
          <p class="series-card__title">New Zealand — North Island</p>
          <p class="series-card__meta">New Zealand · 2025 · 15 images</p>
        </div>
      </a>
      <a href="/work/australia" class="series-card">
        <div class="series-card__placeholder"></div>
        <div class="series-card__info">
          <p class="series-card__title">Australia</p>
          <p class="series-card__meta">Australia · 2025 · 8 images</p>
        </div>
      </a>
      <a href="/work/sheffield-architecture" class="series-card">
        <div class="series-card__placeholder"></div>
        <div class="series-card__info">
          <p class="series-card__title">Sheffield Architecture</p>
          <p class="series-card__meta">United Kingdom · 2024 · 12 images</p>
        </div>
      </a>
      <a href="/work/devon-and-cornwall" class="series-card">
        <div class="series-card__placeholder"></div>
        <div class="series-card__info">
          <p class="series-card__title">Devon & Cornwall</p>
          <p class="series-card__meta">United Kingdom · 2024 · 14 images</p>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>
