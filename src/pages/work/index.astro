---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allSeries = await getCollection('series');
allSeries.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Work — Simon Day">
  <main class="work-index">
    <div class="work-header">
      <h1>Work</h1>
    </div>
    <div class="series-grid">
      {allSeries.map((series) => (
        <a href={`/work/${series.id}`} class="series-card">
          <div class="series-card__image">
            {series.data.coverImage
              ? <img src={series.data.coverImage} alt={series.data.title} loading="lazy" />
              : <div class="series-card__placeholder"></div>
            }
          </div>
          <div class="series-card__meta">
            <h2 class="series-card__title">{series.data.title}</h2>
            <span class="series-card__location">{series.data.location}</span>
            <span class="series-card__year">{series.data.year}</span>
            <span class="series-card__count">{series.data.images.length} images</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
